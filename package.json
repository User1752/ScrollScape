{
  "name": "scrollscape",
  "version": "1.3.0",
  "private": true,
  "main": "server.js",
  "bin": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "build:win":   "pkg . --targets node20-win-x64   --output dist/ScrollScape-win.exe   --compress GZip",
    "build:linux": "pkg . --targets node20-linux-x64 --output dist/ScrollScape-linux     --compress GZip",
    "build:mac":   "pkg . --targets node20-macos-x64 --output dist/ScrollScape-mac       --compress GZip",
    "build:all":   "npm run build:win && npm run build:linux && npm run build:mac",
    "build:exe":   "npm run build:win"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "data/achievements.json",
      "data/icon-mapping.json",
      "node_modules/node-unrar-js/esm/**/*",
      "server/**/*.js"
    ],
    "scripts": [
      "data/sources/**/*.js"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "cheerio": "^1.0.0",
    "compression": "^1.7.4",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "node-unrar-js": "^2.0.2"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.11.0"
  }
}
